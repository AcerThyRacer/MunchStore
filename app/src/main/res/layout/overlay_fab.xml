<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="end">

    <ScrollView
        android:id="@+id/effects_panel_scroll"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginBottom="8dp"
        android:background="@drawable/overlay_panel_bg"
        android:fillViewport="true">
        <LinearLayout
            android:id="@+id/effects_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp" />
    </ScrollView>

    <FrameLayout
        android:id="@+id/fab"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/fab_candy_background"
        android:padding="12dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_fab_candy"
            android:contentDescription="SugarMunch FAB"
            android:scaleType="centerInside"
            android:tint="#FFFFFFFF" />
    </FrameLayout>
</LinearLayout>
