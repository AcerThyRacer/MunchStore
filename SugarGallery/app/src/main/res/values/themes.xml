<?xml version="1.0" encoding="utf-8"?>
<!-- SugarGallery - Theme Resources -->
<resources xmlns:tools="http://schemas.android.com/tools">
    
    <!-- Base SugarGallery Theme -->
    <style name="SugarGalleryTheme" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/sugargallery_primary</item>
        <item name="colorPrimaryVariant">@color/sugargallery_primary_dark</item>
        <item name="colorOnPrimary">@color/sugargallery_on_primary</item>
        
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/sugargallery_accent</item>
        <item name="colorSecondaryVariant">@color/sugargallery_accent_variant</item>
        <item name="colorOnSecondary">@color/sugargallery_on_primary</item>
        
        <!-- Background and surface -->
        <item name="android:colorBackground">@color/sugargallery_background_light</item>
        <item name="colorSurface">@color/sugargallery_surface</item>
        <item name="colorOnSurface">@color/sugargallery_on_surface</item>
        <item name="colorSurfaceVariant">@color/sugargallery_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/sugargallery_on_surface_variant</item>
        
        <!-- Error colors -->
        <item name="colorError">@color/sugargallery_error</item>
        <item name="colorOnError">@android:color/white</item>
        
        <!-- Status bar -->
        <item name="android:statusBarColor">@color/sugargallery_primary</item>
        <item name="android:navigationBarColor">@color/sugargallery_surface</item>
        
        <!-- Window -->
        <item name="android:windowBackground">@color/sugargallery_background_light</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        
        <!-- Ripple -->
        <item name="android:colorControlHighlight">@color/ripple_light</item>
    </style>
    
    <!-- Dark SugarGallery Theme -->
    <style name="SugarGalleryTheme.Dark" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/sugargallery_primary</item>
        <item name="colorPrimaryVariant">@color/sugargallery_primary_dark</item>
        <item name="colorOnPrimary">@color/sugargallery_on_primary</item>
        
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/sugargallery_accent</item>
        <item name="colorSecondaryVariant">@color/sugargallery_accent_variant</item>
        <item name="colorOnSecondary">@color/sugargallery_on_primary</item>
        
        <!-- Background and surface -->
        <item name="android:colorBackground">@color/sugargallery_background_dark</item>
        <item name="colorSurface">@color/sugargallery_surface_dark</item>
        <item name="colorOnSurface">@android:color/white</item>
        <item name="colorSurfaceVariant">@color/sugargallery_surface_dark</item>
        <item name="colorOnSurfaceVariant">@color/sugargallery_on_surface_variant</item>
        
        <!-- Error colors -->
        <item name="colorError">@color/sugargallery_error</item>
        <item name="colorOnError">@android:color/white</item>
        
        <!-- Status bar -->
        <item name="android:statusBarColor">@color/sugargallery_primary</item>
        <item name="android:navigationBarColor">@color/sugargallery_surface_dark</item>
        
        <!-- Window -->
        <item name="android:windowBackground">@color/sugargallery_background_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        
        <!-- Ripple -->
        <item name="android:colorControlHighlight">@color/ripple_dark</item>
    </style>
    
