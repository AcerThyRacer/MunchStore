    <!-- ═════════════════════════════════════════════════════════════════
         DIALOG THEMES
         ═════════════════════════════════════════════════════════════════ -->
    
    <style name="SugarGalleryTheme.Dialog" parent="Theme.Material3.Light.Dialog.Alert">
        <item name="colorPrimary">@color/sugargallery_primary</item>
        <item name="colorSecondary">@color/sugargallery_accent</item>
        <item name="android:windowBackground">@color/sugargallery_surface</item>
        <item name="android:windowCornerRadius">24dp</item>
    </style>
    
    <style name="SugarGalleryTheme.Dialog.Fullscreen" parent="SugarGalleryTheme">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
    
    <!-- ═════════════════════════════════════════════════════════════════
         SPLASH SCREEN THEME
         ═════════════════════════════════════════════════════════════════ -->
    
    <style name="SugarGalleryTheme.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/sugargallery_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_candy_launcher</item>
        <item name="windowSplashScreenAnimationDuration">1000</item>
        <item name="postSplashScreenTheme">@style/SugarGalleryTheme</item>
    </style>
    
    <!-- ═════════════════════════════════════════════════════════════════
         TEXT STYLES
         ═════════════════════════════════════════════════════════════════ -->
    
    <style name="SugarGalleryTheme.Text.Headline">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/sugargallery_on_surface</item>
    </style>
    
    <style name="SugarGalleryTheme.Text.Title">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/sugargallery_on_surface</item>
    </style>
    
    <style name="SugarGalleryTheme.Text.Body">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/sugargallery_on_surface_variant</item>
    </style>
    
    <style name="SugarGalleryTheme.Text.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/sugargallery_on_surface_variant</item>
    </style>
    
    <!-- ═════════════════════════════════════════════════════════════════
         BUTTON STYLES
         ═════════════════════════════════════════════════════════════════ -->
    
    <style name="SugarGalleryTheme.Button.Candy" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/sugargallery_primary</item>
        <item name="android:textColor">@color/sugargallery_on_primary</item>
        <item name="cornerRadius">24dp</item>
    </style>
    
    <style name="SugarGalleryTheme.Button.Candy.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/sugargallery_primary</item>
        <item name="android:textColor">@color/sugargallery_primary</item>
        <item name="cornerRadius">24dp</item>
    </style>
    
    <!-- ═════════════════════════════════════════════════════════════════
         CARD STYLES
         ═════════════════════════════════════════════════════════════════ -->
    
    <style name="SugarGalleryTheme.Card.Candy" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/sugargallery_surface</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
    </style>
    
    <style name="SugarGalleryTheme.Card.Candy.Elevated" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/sugargallery_surface</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">8dp</item>
    </style>
</resources>
